# ============================================================
#  Trader's Edge — Environment Variables
#  Copy this file to ".env.local" and fill in real values.
#  NEVER commit .env.local to git. NEVER expose secret keys
#  to the browser. Only NEXT_PUBLIC_* vars reach the client.
# ============================================================

# --- Supabase (from supabase.com → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key is SECRET — used only in server webhooks to update plans.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Anthropic (from console.anthropic.com) — SECRET, server only ---
ANTHROPIC_API_KEY=sk-ant-your-secret-key

# --- Stripe (from dashboard.stripe.com → Developers → API keys) ---
# Publishable key is safe for the browser; secret key is NOT.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook signing secret (from Stripe → Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price IDs (from Stripe → Products → your price → copy the price ID)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_annual_id

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Free-tier AI usage cap (analyses per user before Pro required) ---
FREE_ANALYSIS_CAP=3

# --- Abuse & cost protection (Upstash Redis — upstash.com, free tier) ---
# If these are blank, rate limiting and the global cap degrade to "allow"
# (fine for local dev; set them in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Per-identifier rate limit: max requests per window (user AND ip each).
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_SECONDS=60
# Global daily ceiling on total AI analyses across all users (hard cost backstop).
DAILY_ANALYSIS_CAP=500
# Max uploaded image size in MB.
MAX_IMAGE_MB=5

# --- Email (Resend.com — for transactional emails) ---
# Optional at first: if RESEND_API_KEY is unset, the app logs intended
# sends to the server console instead of delivering them. This lets you
# ship before email is fully configured.
RESEND_API_KEY=re_your-resend-api-key
# The "From" header on every email. Domain must be verified in Resend.
EMAIL_FROM="Trader's Edge <hello@your-verified-domain.com>"
